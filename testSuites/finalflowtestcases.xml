<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="FinalFlowTestCases" verbose="1">

<listeners>
    <listener class-name="com.sparklingcrown.listeners.TestListener" />
</listeners>

    <test name="Regression">
        <groups>
            <run>
                <include name="finalFlow"/>
            </run>
        </groups>
        <classes>
            <class name="com.sparklingcrown.testall.LoginTest" />
            <class name="com.sparklingcrown.testall.ProductFlowTest" />
            <class name="com.sparklingcrown.testall.FooterTest" />
            <class name="com.sparklingcrown.testall.SearchTests" />
            <class name="com.sparklingcrown.testall.FilterTests" />
        </classes>
    </test>
</suite>
